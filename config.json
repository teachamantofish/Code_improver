{
  "project_name": "my_project_name",
  "task_dir": "improvement/tasks",
  "artifacts_dir": "improvement/artifacts",
  "summary_dir": "improvement/summaries",
  "results_file": "improvement/results.tsv",
  "runner_commands": [
    "env UV_CACHE_DIR=/tmp/uv-cache uv run clean_html.py",
    "env UV_CACHE_DIR=/tmp/uv-cache uv run html_to_md.py"
  ],
  "eval_commands": [
    "env UV_CACHE_DIR=/tmp/uv-cache uv run improvement/evals/html_md_eval.py"
  ],
  "primary_metric": {
    "field": "score",
    "direction": "higher"
  },
  "required_gates": [
    {
      "field": "all_passed",
      "equals": true
    }
  ]
}
